# ============================================================
# .env.example — Template de variáveis de ambiente
# ============================================================
# Para usar: copie este arquivo como .env e preencha os valores.
#   cp .env.example .env
#
# O .env real está no .gitignore (nunca vai para o repositório).
# Este .example é versionado para documentar quais variáveis existem.
# ============================================================

# ---- Banco de Dados ----
DATABASE_URL=jdbc:postgresql://localhost:5432/pixhub
DATABASE_USERNAME=pixhub
DATABASE_PASSWORD=sua_senha_aqui

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---- JWT ----
JWT_SECRET=sua_chave_secreta_aqui_minimo_256_bits
JWT_EXPIRATION_MS=86400000

# ---- Spring ----
SPRING_PROFILES_ACTIVE=dev
